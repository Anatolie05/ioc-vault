generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IocType {
  IP
  DOMAIN
  URL
  HASH
  EMAIL
}

enum Severity {
  MALICIOUS
  SUSPICIOUS
  CLEAN
  UNKNOWN
}

model Ioc {
  id        String   @id @default(uuid())
  value     String
  type      IocType
  severity  Severity
  notes     String?
  createdAt DateTime @default(now())

  @@map("iocs")
}
